{
  "name": "best-way-easy-label-generator",
  "version": "2.0.0",
  "description": "Best Way Easy Label Generator - warehouse location labels with barcodes",
  "author": "Best Way Distribution",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.bestway.labelgenerator",
    "productName": "Best Way Easy Label Generator",
    "win": {
      "target": "portable",
      "signAndEditExecutable": false
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/label-backend.exe",
        "to": "backend/label-backend.exe"
      }
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}
